import java.util.*;

class Main {
    public static void main(String args[]) {
        Scanner ar = new Scanner(System.in);

        int n = ar.nextInt();
        int[] a = new int[n];
        int sum = 0;

        for (int i = 0; i < n; i++) {
            a[i] = ar.nextInt();

            if (a[i] > 0) {
                sum += a[i];
            }
        }

        System.out.println(sum);
    }
}
