import java.util.*;
public class Main
{
	public static void main(String[] args) {
	Scanner sc = new Scanner(System.in);
	int count =0;
        int size=sc.nextInt();
        int arr[]=new int[size];
        for(int i=0;i<size;i++){
            arr[i]=sc.nextInt();
            if(arr[i]%2!=0){
                count++;
            }
            
        }
	System.out.print("Count  "+count);
	    
	}
}
