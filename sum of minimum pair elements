import java.util.*;
public class Main{
    public static void main(String[]args){
        
    Scanner sc = new Scanner(System.in);
    int n = sc.nextInt();
    int sum = 0;
    for(int i = 0 ; i < n; i+=2)
    {
        int a = sc.nextInt();
        int b = sc.nextInt();
        sum += Math. min(a,b);
        
    }
    System.out.println(sum);
    }
}
