import java.util.*;

class Main {
    public static void main(String args[]) {
        Scanner ar = new Scanner(System.in);

        int n = ar.nextInt();
        int[] a = new int[n];

        for (int i = 0; i < n; i++) {
            a[i] = ar.nextInt();
        }

        int max = a[0];

        for (int i = 1; i < n; i++) {
            if (a[i] > max) {
                max = a[i];
            }
        }

        System.out.println(max);
    }
}
